// #popclip
// name: 中英引号互转
// icon: 引
// after: paste-result
// language: javascript
const text = popclip.input.text;
const hasCN = /[\u201C\u201D\u2018\u2019]/.test(text);
if (hasCN) {
  return text
    .replace(/[\u201C\u201D]/g, '"')
    .replace(/[\u2018\u2019]/g, "'");
}
let dq = 0, sq = 0;
return text.replace(/["']/g, (m) => {
  if (m === '"') { dq++; return dq % 2 ? "\u201C" : "\u201D"; }
  sq++;          return sq % 2 ? "\u2018" : "\u2019";
});